{
  "title": "Crawl4AI Input",
  "type": "object",
  "schemaVersion": 1,
  "properties": {
    "startUrls": {
      "title": "Start URLs",
      "type": "array",
      "description": "Starting URLs to visit.",
      "items": {
        "type": "string"
      },
      "prefill": [
        "https://example.com"
      ],
      "editor": "stringList"
    },
    "maxPages": {
      "title": "Max Pages",
      "type": "integer",
      "description": "Maximum pages to process in total.",
      "default": 50,
      "minimum": 1,
      "maximum": 10000
    },
    "maxDepth": {
      "title": "Max Depth",
      "type": "integer",
      "description": "Maximum link depth from each start URL.",
      "default": 2,
      "minimum": 0,
      "maximum": 10
    },
    "concurrency": {
      "title": "Concurrency",
      "type": "integer",
      "description": "Number of concurrent tasks.",
      "default": 5,
      "minimum": 1,
      "maximum": 50
    },
    "requestTimeoutSecs": {
      "title": "Request Timeout (seconds)",
      "type": "integer",
      "description": "Timeout per page request.",
      "default": 60,
      "minimum": 5,
      "maximum": 600
    },
    "headless": {
      "title": "Headless",
      "type": "boolean",
      "description": "Run browser headless.",
      "default": true
    },
    "useProxy": {
      "title": "Use Proxy",
      "type": "boolean",
      "description": "Enable Apify proxy for requests.",
      "default": false
    },
    "proxyGroups": {
      "title": "Proxy Groups",
      "type": "array",
      "description": "Apify proxy groups to use.",
      "items": {
        "type": "string"
      },
      "editor": "stringList"
    },
    "extractMode": {
      "title": "Extract Mode",
      "type": "string",
      "description": "Output format.",
      "default": "markdown",
      "enum": [
        "markdown",
        "html",
        "text"
      ]
    },
    "maxResults": {
      "title": "Max Results",
      "type": "integer",
      "description": "Maximum output items to push.",
      "default": 1000,
      "minimum": 1,
      "maximum": 200000
    },
    "sameDomainOnly": {
      "title": "Same Domain Only",
      "type": "boolean",
      "description": "Only follow links within start URL domains.",
      "default": true
    },
    "includePatterns": {
      "title": "Include URL Patterns",
      "type": "array",
      "description": "Only include URLs matching these regex patterns (optional).",
      "items": {
        "type": "string"
      },
      "editor": "stringList"
    },
    "excludePatterns": {
      "title": "Exclude URL Patterns",
      "type": "array",
      "description": "Exclude URLs matching these regex patterns.",
      "items": {
        "type": "string"
      },
      "editor": "stringList"
    },
    "maxRetries": {
      "title": "Max Retries",
      "type": "integer",
      "description": "Retry failed pages up to this count.",
      "default": 2,
      "minimum": 0,
      "maximum": 10
    },
    "retryBackoffSecs": {
      "title": "Retry Backoff (seconds)",
      "type": "integer",
      "description": "Base backoff in seconds, doubled each retry.",
      "default": 2,
      "minimum": 0,
      "maximum": 120
    },
    "maxRequestsPerMinute": {
      "title": "Max Requests Per Minute",
      "type": "integer",
      "description": "Global rate limit. Set 0 for unlimited.",
      "default": 0,
      "minimum": 0,
      "maximum": 6000
    },
    "enableStealth": {
      "title": "Enable Stealth",
      "type": "boolean",
      "description": "Enable stealth mode for tougher sites.",
      "default": false
    },
    "userAgent": {
      "title": "User Agent",
      "type": "string",
      "description": "Custom user agent string (optional)."
    }
  },
  "required": [
    "startUrls"
  ]
}
